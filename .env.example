# ============================================================
# MU Club Management System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------
# Connection string for your PostgreSQL database.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/mu_club_db

# ------------------------------------------------------------
# SESSION SECRET
# ------------------------------------------------------------
# A long, random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret-string

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
# Port the API server listens on.
PORT=8080

# Node environment: development | production
NODE_ENV=development

# ------------------------------------------------------------
# CORS (Production)
# ------------------------------------------------------------
# Comma-separated list of allowed frontend origins (leave blank for local dev).
# Example: https://mu-portal.vercel.app,https://mu-portal.com
CORS_ORIGIN=

# ------------------------------------------------------------
# OBJECT STORAGE (Replit App Storage — GCS-backed)
# These are set automatically when deploying on Replit.
# For local development, skip image uploads or use a mock bucket.
# ------------------------------------------------------------

# GCS bucket ID provisioned by Replit Object Storage
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# Comma-separated paths for public assets in the bucket
PUBLIC_OBJECT_SEARCH_PATHS=

# Directory path for private uploaded objects
PRIVATE_OBJECT_DIR=

# ------------------------------------------------------------
# NOTES FOR LOCAL SETUP
# ------------------------------------------------------------
# 1. Install dependencies:      pnpm install
# 2. Push DB schema:            pnpm --filter @workspace/db run push
# 3. Seed demo data:            pnpm --filter @workspace/api-server run seed
# 4. Start API server:          pnpm --filter @workspace/api-server run dev
# 5. Start web frontend:        pnpm --filter @workspace/club-portal run dev
#
# Default seeded overseer login: admin / admin123
# ============================================================
