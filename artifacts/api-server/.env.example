# ── Backend (Render) Environment Variables ───────────────────────────────────
# Set these in Render → Service → Environment

# Required: MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/mu-clubs?retryWrites=true&w=majority

# Required: Strong random secret for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Required: Your Vercel frontend URL (used for CORS)
CORS_ORIGIN=https://your-frontend.vercel.app

# Required: Public URL of the frontend (used in password reset emails)
APP_URL=https://your-frontend.vercel.app

# Optional: Replit App Storage (pre-configured on Replit)
# PRIVATE_OBJECT_DIR=...

# ── Email / Nodemailer (for Forgot Password) ──────────────────────────────────
# Use Gmail App Password, SendGrid SMTP, or any SMTP provider

# SMTP provider host
SMTP_HOST=smtp.gmail.com

# SMTP port (587 = TLS/STARTTLS, 465 = SSL)
SMTP_PORT=587

# Use SSL? (true for port 465, false for port 587)
SMTP_SECURE=false

# Your email username / address
SMTP_USER=your-email@gmail.com

# App password (Gmail) or SMTP password
SMTP_PASS=your-app-password

# From address shown in emails (defaults to SMTP_USER if not set)
SMTP_FROM=noreply@metropolitan.edu

# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
